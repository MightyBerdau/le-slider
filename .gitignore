# Excluding virtual Python environments and __pycache__ directories
.venv/
.env/
**/*__pycache__

# Excluding debuggin directories
.vscode/

# Excluding (generated) audio from test scripts
test/**/*.wav

# Excluding any TASCAR log files created allong the way...
**/*.tsc.err
**/*.tsc.out
**/*.tsc.pid

# Excluding Matlab's .asv
**/*.asv

# Excluding anything generated by code
measurement/
**/*.png
**/*.wav

# Excluding tascar directory for Windows users
functions/tascar

# Excluding anything generating .exe files
build/
dist/
**/*.exe
**/*.spec

# Misc
**.pdf